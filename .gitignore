# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Terraform
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it for reproducible builds
crash.log
crash.*.log

# Terraform variable files (may contain secrets)
*.tfvars
!*.tfvars.example
!envs/*/terraform.tfvars

# Backend configs
!envs/*/backend.tfbackend

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup

# Environment files
.env
.env.*
!.env.example

# Secrets - NEVER commit these
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx

# Vault tokens
.vault-token
vault-token
token.txt

# Terraform plan output
*.tfplan
plan.out

# Backups (from make backup)
backups/
tfplan*

# Python virtual environment
.venv/
venv/
__pycache__/
*.pyc
