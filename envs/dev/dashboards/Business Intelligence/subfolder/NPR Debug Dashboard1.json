{
  "description": "Debug dashboard only available in NPR environment",
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "title": "Debug Panel - Request Latency Distribution",
      "type": "heatmap"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 2,
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Debug - Memory Allocation Details",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 3,
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Debug - Goroutines",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "npr",
    "debug",
    "development"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "timezone": "browser",
  "title": "NPR Debug Dashboard1",
  "uid": "npr-debug-dashboard1"
}